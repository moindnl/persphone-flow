# Strava OAuth2 App Credentials
# Erstelle die App unter: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here

# Optional - Redirect URI (Default: http://localhost:5000/callback)
REDIRECT_URI=http://localhost:5000/callback

# Flask Secret Key (für Production ändern!)
FLASK_SECRET_KEY=your-secret-key-here
